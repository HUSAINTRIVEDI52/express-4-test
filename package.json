{
  "name": "express-api-dummy",
  "version": "1.0.0",
  "description": "Dummy project for CI/CD testing",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "jest",
    "lint": "eslint src/**",
    "prepare": "husky || true",
    "test:smoke": "jest --coverage --coverageReporters=lcov text",
    "test:newman": "node tests/run-newman-cloud.mjs",
    "test:all": "npm run test:smoke && npm run test:newman"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "cs-setup": "github:HUSAINTRIVEDI52/pkg#m-main",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "sonarqube-scanner": "^4.3.5",
    "supertest": "^6.3.4"
  }
}
